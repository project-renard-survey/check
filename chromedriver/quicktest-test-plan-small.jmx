      <hashTree/>
      <BeanShellPreProcessor guiclass="TestBeanGUI" testclass="BeanShellPreProcessor" testname="BeanShell PreProcessor" enabled="true">
        <boolProp name="resetInterpreter">false</boolProp>
        <stringProp name="parameters"></stringProp>
        <stringProp name="filename"></stringProp>
        <stringProp name="script">arguments = ctx.getCurrentSampler().getArguments();

for (int i=0; i&lt;arguments.getArgumentCount(); i++) {
      argument = arguments.getArgument(i);
      if (argument.getName().contains(&quot;email&quot;)) {
          String newVal = ctx.getThreadNum().toString()+vars.get(&quot;random_value&quot;).toString()+argument.getValue();
		//print (&quot;+&gt;&quot;+newVal);
          argument.setValue(newVal);
      }
      if (argument.getValue().contains(&quot;\&quot;slug\&quot;:\&quot;team&quot;)){
      	String newVal = argument.getValue();      	
		String v = newVal.replaceAll(&quot;\&quot;slug\&quot;:\&quot;team&quot;, &quot;\&quot;slug\&quot;:\&quot;team&quot;+ctx.getThreadNum().toString()+vars.get(&quot;random_value&quot;).toString()+&quot;-&quot;);
		//print (&quot;+&gt;&quot;+v);
          argument.setValue(v);          
      }
      if (argument.getValue().contains(&quot;\&quot;slug_0\&quot;:\&quot;team&quot;)){
      	String newVal = argument.getValue();      	
		String v = newVal.replaceAll(&quot;\&quot;slug_0\&quot;:\&quot;team&quot;, &quot;\&quot;slug_0\&quot;:\&quot;team&quot;+ctx.getThreadNum().toString()+vars.get(&quot;random_value&quot;).toString()+&quot;-&quot;);
		//print (&quot;+&gt;&quot;+v);
          argument.setValue(v);          
      }
      if (argument.getValue().contains(&quot;\&quot;team\&quot;:\&quot;team&quot;)){
      	String newVal = argument.getValue();      	
		String v = newVal.replaceAll(&quot;\&quot;team\&quot;:\&quot;team&quot;, &quot;\&quot;team\&quot;:\&quot;team&quot;+ctx.getThreadNum().toString()+vars.get(&quot;random_value&quot;).toString()+&quot;-&quot;);
		//print (&quot;+&gt;&quot;+v);
          argument.setValue(v);          
      }
      if (argument.getValue().contains(&quot;\&quot;name\&quot;:\&quot;team&quot;)){
      	String newVal = argument.getValue();      	
		String v = newVal.replaceAll(&quot;\&quot;name\&quot;:\&quot;team&quot;, &quot;\&quot;name\&quot;:\&quot;team&quot;+ctx.getThreadNum().toString()+vars.get(&quot;random_value&quot;).toString()+&quot;-&quot;);
		//print (&quot;+&gt;&quot;+v);
          argument.setValue(v);          
      }
      if (argument.getValue().contains(&quot;\&quot;title\&quot;:\&quot;Project&quot;)){
      	String newVal = argument.getValue();      	
		String v = newVal.replaceAll(&quot;\&quot;title\&quot;:\&quot;Project&quot;, &quot;\&quot;title\&quot;:\&quot;Project&quot;+ctx.getThreadNum().toString()+vars.get(&quot;random_value&quot;).toString()+&quot;-&quot;);
		//print (&quot;+&gt;&quot;+v);
          argument.setValue(v);          
      }

      if (argument.getValue().contains(&quot;\&quot;variables\&quot;:{\&quot;id_0\&quot;:&quot;)){
      	String a = argument.getValue();      	
		print (&quot;\n\nENtradA pR+&gt;&quot;+a);
		String[] lid = vars.get(&quot;project_ids&quot;).split(&quot;,&quot;);
		String end = &quot;&quot;;
		String start = &quot;&quot;;
		if (a.contains(&quot;\&quot;},\&quot;team\&quot;:\&quot;&quot;)){
	     	print (&quot;AQUI&quot;);
			start = a.substring(0,a.indexOf(&quot;\&quot;variables\&quot;:{\&quot;id_0\&quot;:&quot;)+21);
			start = start + lid[lid.length - 1];
			end = a.substring(a.indexOf(&quot;\&quot;},\&quot;team\&quot;:\&quot;&quot;),a.length());    	
	     } else {
	     	print (&quot;AQCASASA&quot;);
			start = a.substring(0,a.indexOf(&quot;\&quot;variables\&quot;:{\&quot;id_0\&quot;:&quot;)+20);
			start = start + lid[lid.length - 1];
			end = a.substring(a.indexOf(&quot;},\&quot;team\&quot;:\&quot;&quot;),a.length());    	
	     }
		String v = start + end;
		print (&quot;\n+FINAL&gt;&quot;+v);
          argument.setValue(v);          
      }
      
      if (argument.getValue().contains(&quot;mutation CreateProject&quot;)){
		a = argument.toString();
		String team = a.substring(a.indexOf(&quot;\&quot;team\&quot;:&quot;)+8,a.length()-2);
		String id = a.substring(a.indexOf(&quot;\&quot;team_id\&quot;:&quot;)+10,a.indexOf(&quot;,\&quot;clientMutationId&quot;));	
		String[] li = vars.get(&quot;team_ids&quot;).split(&quot;,&quot;);
		String[] lu = vars.get(&quot;team_slugs&quot;).split(&quot;,&quot;);
		for (int i = 0; i &lt; lu.length; i++) {
		  if (lu[i].equals(team)){
		      id = li[i];
		  }
		}
		String v = a.substring(1,a.indexOf(&quot;\&quot;team_id\&quot;:&quot;)+10) + id ;
		v = v + a.substring(a.indexOf(&quot;,\&quot;clientMutationId&quot;) , a.indexOf(&quot;\&quot;team\&quot;:&quot;)+8);
		v = v +team + &quot;\&quot;}&quot;;
		argument.setValue(v);    
	 }
}
sampler.setArguments(arguments);  
</stringProp>
      </BeanShellPreProcessor>
      <hashTree/>
      <BeanShellPostProcessor guiclass="TestBeanGUI" testclass="BeanShellPostProcessor" testname="BeanShell PostProcessor" enabled="true">
        <stringProp name="filename"></stringProp>
        <stringProp name="parameters"></stringProp>
        <boolProp name="resetInterpreter">false</boolProp>
        <stringProp name="script">response = prev.getResponseDataAsString();

if (response.contains(&quot;\&quot;data\&quot;:{\&quot;createTeam&quot;)){
     print (response);
	String s =  vars.get(&quot;team_ids&quot;);
	String u =  vars.get(&quot;team_slugs&quot;);
	print (&quot; \n *STAR**&quot;);
	id = response.substring(response.indexOf(&quot;dbid&quot;)+6 , response.indexOf(&quot;,\&quot;slug&quot;));
	slug = response.substring(response.indexOf(&quot;slug&quot;)+7 , response.indexOf(&quot;\&quot;,\&quot;description&quot;));
	if (s.length() &gt; 0 ){
		s = s + &quot;,&quot; + id;
		vars.put(&quot;team_ids&quot;, s);
		u = u + &quot;,&quot; + slug;
		vars.put(&quot;team_slugs&quot;, u);

	} else {
		vars.put(&quot;team_ids&quot;, id);
		vars.put(&quot;team_slugs&quot;, slug);		
	}
	print (&quot;ARRAYS team == &quot;);
	print (vars.get(&quot;team_ids&quot;));
	print (vars.get(&quot;team_slugs&quot;));
	print (&quot;FIM TEAM ******* \n  \n&quot;);
}


if (response.contains(&quot;\&quot;data\&quot;:{\&quot;createProject&quot;)){
	print (&quot; \n *STAR project RESPONSE**&quot;);
     print (response);
	String s =  vars.get(&quot;project_ids&quot;);
	String u =  vars.get(&quot;project_titles&quot;);
	id = response.substring(response.indexOf(&quot;dbid&quot;)+6 , response.indexOf(&quot;,\&quot;id\&quot;:&quot;));
	slug = response.substring(response.indexOf(&quot;title&quot;)+7 , response.indexOf(&quot;\&quot;,\&quot;dbid&quot;));
	if (s.length() &gt; 0 ){
		s = s + &quot;,&quot; + id;
		vars.put(&quot;project_ids&quot;, s);
		u = u + &quot;,&quot; + slug;
		vars.put(&quot;project_titles&quot;, u);

	} else {
		vars.put(&quot;project_ids&quot;, id);
		vars.put(&quot;project_titles&quot;, slug);		
	}
	print (&quot;ARRAYS proj == &quot;);
	print (vars.get(&quot;project_ids&quot;));
	print (vars.get(&quot;project_titles&quot;));
	print (&quot;FIM POST PROJECT******* \n  \n&quot;);


}</stringProp>
      </BeanShellPostProcessor>
